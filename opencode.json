{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "postgres://postgres:postgres@localhost:5432/postgres"]
    },
    "tanstack": {
      "type": "local",
      "command": ["npx", "@tanstack/cli", "mcp"]
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"]
    }
  }
}
